# ==============================================================================
# ViralOps Frontend Environment Configuration (.env.vercel)
# Used for Vercel deployments.
# ==============================================================================

# Backend API URL
# Must point to the Render web service URL (e.g., https://viralops-api.onrender.com)
VITE_API_BASE_URL=https://your-backend-render-url.onrender.com

# OAuth configuration (must match backend allowed origins)
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id
