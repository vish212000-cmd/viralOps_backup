# ==============================================================================
# ViralOps Backend Environment Configuration (.env.render)
# Used for Render web and worker deployments.
# ==============================================================================

# Django settings
DJANGO_SETTINGS_MODULE=viralops.settings.staging
SECRET_KEY=generate-a-secure-random-string-in-render-dashboard
SECURE_SSL_REDIRECT=True
FRONTEND_URL=https://viralops-staging.vercel.app

# Database Configuration (Neon PostgreSQL)
# Example: postgres://[user]:[password]@[endpoint]/[dbname]?sslmode=require
DATABASE_URL=your-neon-postgres-connection-string

# Celery & Cache Backend Configurations (Upstash Redis)
# Example: rediss://default:[password]@[endpoint]:[port]
CELERY_BROKER_URL=your-upstash-redis-connection-string
CELERY_RESULT_BACKEND=your-upstash-redis-connection-string

# Google AI Core Service API
GEMINI_API_KEY=your-gemini-api-key-here

# Google OAuth Credentials
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# Sentry Observability Configuration
SENTRY_DSN=your-sentry-dsn
SENTRY_ENV=staging
SENTRY_RELEASE=commit-hash
