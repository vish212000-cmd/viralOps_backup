# ==============================================================================
# ViralOps Environment Configurations Template (.env.example)
# Copy this file to '.env' and fill in the values for production or local deployment.
# ==============================================================================

# Django settings
SECRET_KEY=your-production-django-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
SECURE_SSL_REDIRECT=False

# Database Configuration (MySQL production config)
DB_NAME=viralops
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_HOST=db
DB_PORT=3306

# Celery & Cache Backend Configurations
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Google AI Core Service API
GEMINI_API_KEY=your-gemini-api-key-here

# Google OAuth Credentials (for django-allauth)
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret-here

# Razorpay Subscription Billing Credentials
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your-razorpay-secret-key
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-signing-secret

# AWS S3 Storage Credentials (Optional, dynamic filesystem fallback if empty)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
AWS_S3_REGION_NAME=us-east-1

# Speech-to-Text Providers (Optional, fallback to simulated transcription if empty)
OPENAI_API_KEY=your-openai-api-key
ASSEMBLYAI_API_KEY=your-assemblyai-api-key
TRANSCRIPTION_PROVIDER=whisper # whisper or assemblyai

# Email Settings (Optional SMTP server, fallback to console log if empty)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@viralops.com
EMAIL_VERIFICATION_REQUIRED=True

# Frontend URL
FRONTEND_URL=http://localhost:5173

# CORS Allowed Origins (comma-separated list of origins allowed to access the API)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# Sentry Observability Configuration
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_ENV=
